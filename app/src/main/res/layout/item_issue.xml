<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#EEFFFFFF"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/issuePriorityImageView"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="priorité" />

        <TextView
            android:id="@+id/issueTitleTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Titre"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#222222" />

    </LinearLayout>

    <TextView
        android:id="@+id/issueDescriptionTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Description"
        android:maxLines="3"
        android:textColor="#444444"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/issuePriorityTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gravité"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/issueStatusTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="État"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginTop="4dp" />

    <RatingBar
        android:id="@+id/issueRatingBar"
        style="?android:attr/ratingBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="1.0"
        android:rating="1"
        android:layout_marginTop="6dp" />

</LinearLayout>