<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/fond"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA006D77" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alerte Accident"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="28sp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#EEFFFFFF"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/detailPriorityDot"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="8dp"
                            android:contentDescription="priority detail" />

                        <TextView
                            android:id="@+id/detailPriority"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Priorité"
                            android:textColor="#444444"
                            android:textStyle="bold"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/detailTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Titre incident"
                        android:textColor="#111111"
                        android:textStyle="bold"
                        android:textSize="24sp" />

                    <RatingBar
                        android:id="@+id/detailRatingBar"
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:numStars="5"
                        android:stepSize="1.0"
                        android:rating="0" />

                    <TextView
                        android:id="@+id/detailDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Description"
                        android:textColor="#333333"
                        android:textSize="16sp"
                        android:lineSpacingExtra="3dp" />

                    <TextView
                        android:id="@+id/detailProtocol"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Protocole :"
                        android:textColor="#5A2EA6"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/detailAccidentImage"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:layout_marginTop="14dp"
                        android:scaleType="centerCrop"
                        android:background="#E0E0E0"
                        android:contentDescription="Photo de l'accident"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/detailLocationText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Localisation GPS"
                        android:textColor="#333333"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <org.osmdroid.views.MapView
                        android:id="@+id/detailMap"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/goButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voir les incidents"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/purple_500" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>