<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/primary"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/detailPriorityDot"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/bg_priority_low" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/detailTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Interface Secours"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:id="@+id/detailPriority"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sélectionnez un incident"
                        android:textSize="13sp"
                        android:textColor="#B3E5FC"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Info card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/detailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Appuyez sur un incident dans la liste pour voir les détails ici."
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/detailProtocol"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Protocole : aucun"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <RatingBar
                    android:id="@+id/detailRatingBar"
                    style="?android:attr/ratingBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:numStars="5"
                    android:stepSize="1" />

                <TextView
                    android:id="@+id/detailStatusLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Statut intervention"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- GPS card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/detailLocationText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📍 Localisation GPS : aucune sélection"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <org.osmdroid.views.MapView
                    android:id="@+id/detailMap"
                    android:layout_width="match_parent"
                    android:layout_height="220dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Camera card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="12dp">

            <fragment
                android:id="@+id/cameraFragment"
                android:name="com.example.td2ex2.CameraFragment"
                android:layout_width="match_parent"
                android:layout_height="260dp" />

        </androidx.cardview.widget.CardView>

        <!-- Actions card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/surface"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Actions secours"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnSendPatrol"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🚔  Envoyer une patrouille"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/primary"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnCallRescue"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🚑  Contacter les secours"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/success"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnReinforcement"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🆘  Demander du renfort"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/danger"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/goButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="📋  Voir la liste des incidents"
                    android:textAllCaps="false"
                    android:textColor="@color/primary"
                    android:backgroundTint="@color/primary_light" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
