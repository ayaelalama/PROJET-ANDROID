<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#21C7E8"
    android:padding="22dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tour de contrôle des secours"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="24sp"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/alertsTextView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Aucune alerte pour le moment."
        android:textColor="#B00020"
        android:textSize="15sp"
        android:background="#EEFFFFFF"
        android:padding="14dp" />

    <Button
        android:id="@+id/refreshAlertsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Actualiser les alertes"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6200EE"
        android:layout_marginTop="14dp" />

</LinearLayout>